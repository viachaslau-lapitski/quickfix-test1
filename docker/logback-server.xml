<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ═══════════════════════════════════════════════════════════════════
         Appenders
         ═══════════════════════════════════════════════════════════════════ -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- Suppress INFO events that propagate here via logger additivity -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- DEBUG output from MINA/QFJ internals goes here, NOT to console. -->
    <appender name="DEBUG_FILE" class="ch.qos.logback.core.FileAppender">
        <file>/app/server-debug.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <!-- Structured session events written by the inline LogFactory in ServerApp. -->
    <appender name="ERRORS_FILE" class="ch.qos.logback.core.FileAppender">
        <file>/app/server-errors.log</file>
        <append>true</append>
        <encoder>
            <pattern>%msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <!-- ═══════════════════════════════════════════════════════════════════
         Package-level DEBUG routing → DEBUG_FILE
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MINA SSL handshake / record-layer debug -->
    <logger name="org.apache.mina.filter.ssl" level="DEBUG" additivity="false">
        <appender-ref ref="DEBUG_FILE"/>
    </logger>

    <!-- Uncomment to capture all QuickFIX/J internal debug:
    <logger name="quickfix" level="DEBUG" additivity="false">
        <appender-ref ref="DEBUG_FILE"/>
    </logger>
    -->

    <!-- Uncomment to capture everything at DEBUG level:
    <root level="DEBUG">
        <appender-ref ref="DEBUG_FILE"/>
    </root>
    -->

    <!-- ═══════════════════════════════════════════════════════════════════
         Server session events logger
         WARN/ERROR also propagate to root → appear on console too.
         ═══════════════════════════════════════════════════════════════════ -->
    <logger name="server.errors" level="INFO" additivity="true">
        <appender-ref ref="ERRORS_FILE"/>
    </logger>

    <!-- ═══════════════════════════════════════════════════════════════════
         Root — console only, WARN+
         ═══════════════════════════════════════════════════════════════════ -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
